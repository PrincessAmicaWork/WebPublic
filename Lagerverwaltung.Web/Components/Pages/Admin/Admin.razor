    private async Task<bool> CompleteHandover(
        EquipmentRequest req,
        RequestFulfillmentType fulfillmentType)
    {
        if (_actionBusy)
            return false;

        _actionBusy = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var (ok, error) = await EquipmentSvc.CompleteHandoverAsync(
                req.Id,
                _isAdmin,
                fulfillmentType);

            if (!ok)
            {
                Snackbar.Add(error, Severity.Error);
                return false;
            }

            if (!string.IsNullOrWhiteSpace(error))
            {
                Snackbar.Add(error, Severity.Warning);
            }

            if (fulfillmentType == RequestFulfillmentType.NewFromStock)
            {
                Snackbar.Add(
                    $"{req.DisplayTicketNumber}: Neuware wurde aus dem Lager ausgebucht.",
                    Severity.Success);
            }
            else
            {
                Snackbar.Add(
                    $"{req.DisplayTicketNumber}: Gebrauchtgerät wurde aus dem Lager ausgegeben.",
                    Severity.Success);
            }

            _currentView = AdminView.Collected;

            await ReloadAndRender();
            return true;
        }
        finally
        {
            _actionBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }
