<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2" />
            Artikel bearbeiten
        </MudText>
    </TitleContent>

    <DialogContent>
        @if (Item is null)
        {
            <MudAlert Severity="Severity.Error">Artikel konnte nicht geladen werden.</MudAlert>
        }
        else
        {
            <MudPaper Class="pa-3 mb-4" Elevation="0" Style="background:#f8fafc;border:1px solid #e5e7eb;border-radius:8px;">
                <MudText Typo="Typo.caption">Positions-ID</MudText>
                <MudText Typo="Typo.body1"><b>@Item.PositionId</b></MudText>
                <MudText Typo="Typo.caption" Class="d-block mt-1">Aktueller Status: @Item.StatusText</MudText>
            </MudPaper>

            <MudForm @ref="_form">
                <MudSelect T="int"
                           Label="Kategorie"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Required="true"
                           RequiredError="Bitte eine Kategorie wählen."
                           @bind-Value="_model.CategoryId"
                           Class="mb-3">
                    @foreach (var category in Categories)
                    {
                        <MudSelectItem T="int" Value="@category.ID">@category.Name?.Trim()</MudSelectItem>
                    }
                </MudSelect>

                <MudSelect T="StockCondition"
                           Label="Zustand"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           @bind-Value="_model.StockCondition"
                           Class="mb-3">
                    <MudSelectItem T="StockCondition" Value="StockCondition.New">Neu</MudSelectItem>
                    <MudSelectItem T="StockCondition" Value="StockCondition.Used">Gebraucht</MudSelectItem>
                </MudSelect>

                <MudTextField T="string"
                              Label="Beschreibung"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Required="true"
                              RequiredError="Beschreibung ist erforderlich."
                              @bind-Value="_model.Description"
                              Class="mb-3" />

                <MudTextField T="string"
                              Label="Bestellnummer / Interne Nr."
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="_model.OrderNumber"
                              Class="mb-3" />

                <MudTextField T="string"
                              Label="Lieferant"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="_model.Supplier"
                              Class="mb-3" />

                <MudNumericField T="double"
                                 Label="Preis"
                                 Min="0"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 @bind-Value="_model.Price"
                                 Class="mb-3" />

                <MudDatePicker Label="Kaufdatum"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               @bind-Date="_model.PurchaseDate"
                               Class="mb-3" />
            </MudForm>
        }
    </DialogContent>

    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">Abbrechen</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="Item is null"
                   OnClick="Submit">
            Speichern
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public StorageItemRow? Item { get; set; }

    [Parameter] public List<Category> Categories { get; set; } = new();

    private MudForm _form = null!;

    private EditStorageItemModel _model = new();

    protected override void OnInitialized()
    {
        if (Item is null)
            return;

        _model = new EditStorageItemModel
        {
            PositionId = Item.PositionId,
            CategoryId = Item.CategoryId,
            Description = Item.Description,
            OrderNumber = Item.OrderNumber,
            Supplier = Item.Supplier,
            Price = Item.Price,
            PurchaseDate = Item.PurchaseDate,
            StockCondition = Item.StockCondition
        };
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task Submit()
    {
        if (Item is null)
            return;

        await _form.ValidateAsync();

        if (!_form.IsValid)
            return;

        var request = new UpdateStorageItemRequest(
            PositionId: _model.PositionId,
            CategoryId: _model.CategoryId,
            Description: _model.Description,
            OrderNumber: _model.OrderNumber,
            Supplier: _model.Supplier,
            Price: _model.Price,
            PurchaseDate: _model.PurchaseDate ?? DateTime.Today,
            StockCondition: _model.StockCondition);

        MudDialog.Close(DialogResult.Ok(request));
    }

    private sealed class EditStorageItemModel
    {
        public int PositionId { get; set; }
        public int CategoryId { get; set; }
        public string Description { get; set; } = "";
        public string OrderNumber { get; set; } = "";
        public string Supplier { get; set; } = "";
        public double Price { get; set; }
        public DateTime? PurchaseDate { get; set; } = DateTime.Today;
        public StockCondition StockCondition { get; set; } = StockCondition.New;
    }
}
