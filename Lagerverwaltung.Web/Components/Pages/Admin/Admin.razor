    private async Task OpenAssignPositionDialog(EquipmentOrderLine line)
    {
        if (_actionBusy)
            return;

        // Reset the dialog state before loading options. Without this, a failed lookup
        // can leave the previously selected line visible in the dialog.
        _assignPositionDialogOpen = false;
        _assignPositionTargetLine = line;
        _assignPositionOptions = new();
        _selectedPositionId = 0;

        _actionBusy = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var (ok, error, positions) = await OrderSvc.GetAvailablePositionsForLineAsync(
                line.EquipmentOrderId,
                line.Id,
                CurrentUser.Email,
                _isAdmin);

            if (!ok)
            {
                _assignPositionTargetLine = null;
                Snackbar.Add(error, Severity.Error);
                return;
            }

            _assignPositionOptions = positions;
            _selectedPositionId = positions.FirstOrDefault()?.PositionId ?? 0;
            _assignPositionDialogOpen = true;
        }
        finally
        {
            _actionBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

