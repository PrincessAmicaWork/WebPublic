@inject AuthenticationStateProvider AuthStateProvider

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav-menu-stack">
        <div class="nav-primary-links">
            <div class="nav-item">
                <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                    <MudIcon Icon="@Icons.Material.Filled.AddShoppingCart" Class="me-3" />
                    Neue Bestellung
                </NavLink>
            </div>

            <div class="nav-item">
                <NavLink class="nav-link" href="/my-requests">
                    <MudIcon Icon="@Icons.Material.Filled.Assignment" Class="me-3" />
                    <span class="nav-link-label nav-link-label--stacked">
                        <span>Meine</span>
                        <span>Bestellungen</span>
                    </span>
                </NavLink>
            </div>
        </div>

        @if (_showAdmin)
        {
            <div class="nav-admin-block">
                <div class="nav-section-header">@(_isAdmin ? "ADMIN" : "FREIGABE")</div>

                <div class="nav-item">
                    <NavLink class="nav-link" href="/admin" Match="NavLinkMatch.All">
                        <MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="me-3" />
                        @(_isAdmin ? "Admin Panel" : "Meine Freigaben")
                    </NavLink>
                </div>

                @if (_isAdmin)
                {
                    <div class="nav-item">
                        <NavLink class="nav-link" href="/admin/storage" Match="NavLinkMatch.Prefix">
                            <MudIcon Icon="@Icons.Material.Filled.Warehouse" Class="me-3" />
                            Lager
                        </NavLink>
                    </div>

                    <div class="nav-item">
                        <NavLink class="nav-link" href="/admin/catalog" Match="NavLinkMatch.Prefix">
                            <MudIcon Icon="@Icons.Material.Filled.Inventory2" Class="me-3" />
                            <span class="nav-link-label nav-link-label--stacked">
                                <span>Standort</span>
                                <span>Katalog</span>
                            </span>
                        </NavLink>
                    </div>

                    <div class="nav-item">
                        <NavLink class="nav-link" href="/legacy-catalog" Match="NavLinkMatch.Prefix">
                            <MudIcon Icon="@Icons.Material.Filled.Inventory2" Class="me-3" />
                            Legacy Katalog
                        </NavLink>
                    </div>
                }
            </div>
        }

        <div class="nav-spacer"></div>

        <div class="nav-bottom-block">
            <div class="nav-item nav-item--logout">
                <NavLink class="nav-link" href="/logout">
                    <MudIcon Icon="@Icons.Material.Filled.Logout" Class="me-3" />
                    Logout
                </NavLink>
            </div>

            <div class="nav-footer">
                <MudLink Href="https://sites.google.com/view/smitereadme" Typo="Typo.caption" Target="_blank">App Changelog & Roadmap</MudLink>
                <MudText Typo="Typo.caption">© Bosch GmbH Internal Use Only</MudText>
            </div>
        </div>
    </nav>
</div>

@code {
    private bool _showAdmin;
    private bool _isAdmin;
    private bool _isSupervisor;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        _isAdmin = user.IsInRole("Lagerverwaltung.Admin");
        _isSupervisor = user.IsInRole("Lagerverwaltung.Supervisor");

        _showAdmin = _isAdmin || _isSupervisor;
    }
}